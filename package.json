{
  "name": "hangout",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/lib/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:d1:local": "wrangler d1 migrations apply hangout-dev --local",
    "db:d1:remote": "wrangler d1 migrations apply hangout-dev --remote",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:dry-run": "wrangler deploy --dry-run",
    "eval": "tsx --tsconfig eval/tsconfig.json eval/run.ts",
    "eval:quick": "tsx --tsconfig eval/tsconfig.json eval/run.ts --sample 50",
    "eval:regression": "tsx --tsconfig eval/tsconfig.json eval/run.ts --regression"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@clerk/nextjs": "^7.4.3",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "groq-sdk": "^1.2.1",
    "lucide-react": "^1.17.0",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "svix": "^1.95.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
